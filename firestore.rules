rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function getRole() { return request.auth.token.role; }
    function isAdmin() { return isAuth() && (getRole() == 'admin' || getRole() == 'admingeral'); }
    function isChefeOrAdmin() { return isAuth() && (getRole() == 'chefe' || getRole() == 'admin' || getRole() == 'admingeral'); }
    function isAdminGeral() { return isAuth() && getRole() == 'admingeral'; }

    // Block everything by default
    match /{document=**} { allow read, write: if false; }

    // Users: any authenticated reads, admin writes (hierarchy enforced)
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAdmin()
        && (isAdminGeral() || request.resource.data.role != 'admingeral');
      allow update: if isAdmin()
        && (isAdminGeral() || (resource.data.role != 'admingeral' && request.resource.data.role != 'admingeral'));
      allow delete: if isAdmin()
        && (isAdminGeral() || resource.data.role != 'admingeral');
    }

    // User secrets (passwords): ONLY admingeral reads, Cloud Functions write via Admin SDK
    match /user_secrets/{userId} {
      allow read: if isAdminGeral();
      allow write: if false;
    }

    // Materials: all auth read, admin full CRUD, chefe can update (stock adjustment during conferência)
    match /materials/{docId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isChefeOrAdmin();
    }

    // Categories: all auth read, admin only write
    match /categorias/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Vehicles: all auth read, admin full CRUD, chefe can update (ultima_conferencia timestamp)
    match /viaturas/{docId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isChefeOrAdmin();
    }

    // Vehicle materials (allocation records): all auth read, admin full CRUD, chefe can update (conferência)
    match /viatura_materiais/{docId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isChefeOrAdmin();
    }

    // Movements (cautela records)
    match /movimentacoes/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow delete: if isAdminGeral();
      allow update: if isAdmin()
        || (isAuth()
            && resource.data.user == request.auth.token.firestoreId
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['signed', 'signed_date', 'user_acknowledged_return']))
        || (isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['anexos']));
    }

    // Rings
    match /rings/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Maintenance
    match /manutencoes/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Maintenance history
    match /historico_manutencoes/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Vehicle conference history: all auth read, chefe+admin create, admin update/delete
    match /conferencias_viaturas/{docId} {
      allow read: if isAuth();
      allow create: if isChefeOrAdmin();
      allow update, delete: if isAdmin();
    }

    // Conference alerts (chefe → admin): admin reads+updates, chefe+admin creates
    match /alertas_conferencia/{docId} {
      allow read: if isAdmin();
      allow create: if isChefeOrAdmin();
      allow update: if isAdmin();
      allow delete: if isAdminGeral();
    }

    // Audit logs: any authenticated user can write, only admingeral can read
    match /audit_logs/{docId} {
      allow read: if isAdminGeral();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Tarefas DEMOP: all auth reads, admingeral full control, admin can update progress/completion
    match /tarefas_demop/{docId} {
      allow read: if isAuth();
      allow create, delete: if isAdminGeral();
      allow update: if isAdminGeral()
        || (isAdmin()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['progress', 'status', 'completedAt', 'completedBy', 'completedByName']));
    }
  }
}
